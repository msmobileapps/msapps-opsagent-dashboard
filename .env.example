# MSApps OpsAgent Dashboard — Environment Variables

# API base URL (leave empty for same-origin in production)
VITE_API_BASE=

# API key for authenticated endpoints (optional, matches OPSAGENT_API_KEY on server)
VITE_API_KEY=

# Server port
PORT=4243

# Google OAuth (for Calendar integration in production)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
